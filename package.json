{
  "name": "tech-coach",
  "version": "0.1.0-alpha.1",
  "private": true,
  "type": "module",
  "bin": {
    "archcoach": "bin/archcoach"
  },
  "packageManager": "bun@1.2.17",
  "scripts": {
    "build:cli": "bun build packages/cli/src/index.ts --target=node --outfile dist/cli.js",
    "build:mcp": "bun build mcp/server/index.ts --target=node --outfile dist/mcp-server.js",
    "test": "vitest run",
    "test:claude-e2e": "scripts/e2e-claude-brownfield.sh",
    "test:claims-e2e": "bun scripts/evaluate-brownfield-claims.ts --run-claude",
    "test:persistence": "bun test packages/persistence/src/persistence.integration.test.ts packages/evaluation/src/persistenceE2E.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
